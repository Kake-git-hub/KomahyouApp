rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function memberDoc(workspaceKey) {
      return /databases/$(database)/documents/workspaces/$(workspaceKey)/members/$(request.auth.uid);
    }

    function hasWorkspaceMembership(workspaceKey) {
      return isSignedIn() && exists(memberDoc(workspaceKey));
    }

    function workspaceRole(workspaceKey) {
      return get(memberDoc(workspaceKey)).data.role;
    }

    function assignedClassroomId(workspaceKey) {
      return get(memberDoc(workspaceKey)).data.assignedClassroomId;
    }

    function isDeveloper(workspaceKey) {
      return hasWorkspaceMembership(workspaceKey) && workspaceRole(workspaceKey) == 'developer';
    }

    function isBillingDeveloper(workspaceKey) {
      return isDeveloper(workspaceKey)
        && (
          get(memberDoc(workspaceKey)).data.email == 'dai.in.the.mood@gmail.com'
          || get(memberDoc(workspaceKey)).data.email == 'bkkdmzn@gmail.com'
          || get(memberDoc(workspaceKey)).data.email == 'd.ishikawa@agc-akasaka.com'
          || request.auth.token.email == 'dai.in.the.mood@gmail.com'
          || request.auth.token.email == 'bkkdmzn@gmail.com'
          || request.auth.token.email == 'd.ishikawa@agc-akasaka.com'
        );
    }

    function canAccessClassroom(workspaceKey, classroomId) {
      return hasWorkspaceMembership(workspaceKey)
        && (
          workspaceRole(workspaceKey) == 'developer'
          || assignedClassroomId(workspaceKey) == classroomId
        );
    }

    match /workspaces/{workspaceKey} {
      allow read: if hasWorkspaceMembership(workspaceKey);
      allow write: if isDeveloper(workspaceKey);

      match /members/{userId} {
        allow read: if isDeveloper(workspaceKey) || (hasWorkspaceMembership(workspaceKey) && request.auth.uid == userId);
        allow write: if isDeveloper(workspaceKey);
      }

      match /classrooms/{classroomId} {
        allow read: if canAccessClassroom(workspaceKey, classroomId);
        allow write: if isDeveloper(workspaceKey);
      }

      // A3: 教室スナップショット/設定の保存は Cloud Function(saveClassroomSnapshot)へ一本化済み。
      // 通常保存は Admin SDK でルールを迂回するため、クライアント直書き(create/update)は
      // 「保存の裏口」(版数照合・空データ拒否・読み戻し検証を素通り)になる。
      // マネージャーは直書きしない(CF経由)ので、直書きは開発者のみに限定する。
      // 読み取りは従来通り(教室アクセス権)に保つ。delete は従来通り開発者のみ。
      match /classroomSnapshots/{classroomId} {
        allow read: if canAccessClassroom(workspaceKey, classroomId);
        // 開発者の教室作成(provisionFirebaseWorkspaceClassroomWithExistingUid)で初期スナップショットを直書きする。
        allow create, update: if isDeveloper(workspaceKey);
        allow delete: if isDeveloper(workspaceKey);

        // chunks/parts/boardWeeks は旧「分割保存」の名残。現在クライアントから書く経路は無い。
        // 古い分割データの読み取りだけ残し、書き込みは開発者のみに閉じる。
        match /chunks/{chunkId} {
          allow read: if canAccessClassroom(workspaceKey, classroomId);
          allow create, update, delete: if isDeveloper(workspaceKey);
        }

        match /parts/{partId} {
          allow read: if canAccessClassroom(workspaceKey, classroomId);
          allow create, update, delete: if isDeveloper(workspaceKey);
        }

        match /boardWeeks/{weekId} {
          allow read: if canAccessClassroom(workspaceKey, classroomId);
          allow create, update, delete: if isDeveloper(workspaceKey);
        }
      }

      // classroomSettings は現在クライアントから書く経路が無い(読み取りのみの旧フォールバック)。
      // 念のため読み取りは残し、書き込みは開発者のみに閉じる。
      match /classroomSettings/{classroomId} {
        allow read: if canAccessClassroom(workspaceKey, classroomId);
        allow create, update: if isDeveloper(workspaceKey);
        allow delete: if isDeveloper(workspaceKey);
      }

      match /workspaceAutoBackupSummaries/{backupDateKey} {
        allow read: if hasWorkspaceMembership(workspaceKey);
        allow write: if false;
      }

      match /billingMonths/{monthKey} {
        allow read, write: if isBillingDeveloper(workspaceKey);

        match /classrooms/{classroomId} {
          allow read, write: if isBillingDeveloper(workspaceKey);
        }
      }
    }

    match /boardShares/{token} {
      allow read: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // Lecture submissions: admin creates/deletes, Cloud Functions handle public access
    match /lectureSubmissions/{token} {
      allow read, write: if isSignedIn();
    }
  }
}