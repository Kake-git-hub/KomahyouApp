{
  "name": "komahyouapp",
  "private": true,
  "version": "1.4.7",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:firebase": "npm run build",
    "build:functions": "npm --prefix functions run build",
    "firebase:first-classroom": "node tools/firebase-first-classroom-helper.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy:firebase": "npm run build:firebase && npx firebase-tools deploy --only hosting,firestore",
    "deploy:firebase:with-functions": "npm run build:firebase && npm run build:functions && npx firebase-tools deploy --only hosting,firestore,functions",
    "emulators:firebase": "npm run build && npx firebase-tools emulators:start --only auth,firestore,hosting",
    "test:unit": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "firebase": "^12.11.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
